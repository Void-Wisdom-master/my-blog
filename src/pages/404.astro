---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title="404: Not Found" description="Page not found" />
		<style>
			main {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				min-height: 50vh;
				text-align: center;
			}
			h1 {
				font-size: 4rem;
				margin: 0;
			}
			p {
				font-size: 1.5rem;
				color: var(--gray);
			}
			.back-home {
				margin-top: 2rem;
				padding: 0.5rem 1rem;
				background: var(--accent);
				color: white;
				text-decoration: none;
				border-radius: 4px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>404</h1>
			<p>{lang === 'zh' ? '抱歉，您访问的页面不存在。' : 'Sorry, the page you are looking for does not exist.'}</p>
			<a href={translatePath('/')} class="back-home">
				{lang === 'zh' ? '返回首页' : 'Go back home'}
			</a>
		</main>
		<Footer />
	</body>
</html>
