---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 900px;
				margin: 0 auto;
				padding: 6rem 2rem;
			}
			.about-container {
				display: grid;
				grid-template-columns: 1.5fr 1fr;
				gap: 3rem;
				align-items: center;
			}
			.content-side {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			.intro-section h1 {
				font-size: 3rem;
				margin: 0 0 0.5rem 0;
				font-weight: 800;
				letter-spacing: -0.02em;
				line-height: 1.2;
				color: var(--black);
			}
			.intro-section .description {
				font-size: 1.1rem;
				color: var(--gray);
				line-height: 1.5;
			}
			.image-side {
				display: flex;
				justify-content: flex-end;
			}
			.image-wrapper {
				width: 100%;
				max-width: 360px;
				border-radius: 1.5rem;
				overflow: hidden;
				box-shadow: var(--box-shadow);
				aspect-ratio: 4 / 5;
				background: var(--gray-light);
			}
			.image-wrapper img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.prose-section {
				font-size: 1.125rem;
				line-height: 1.8;
				color: var(--gray-dark);
			}
			.prose-section h2 {
				font-size: 1.5rem;
				margin-top: 1.5rem;
				border: none;
				padding: 0;
			}
			@media (max-width: 768px) {
				.about-container {
					grid-template-columns: 1fr;
					text-align: center;
				}
				.image-side { justify-content: center; order: -1; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-container">
				<div class="content-side">
					<div class="intro-section">
						<h1>{title}</h1>
						<p class="description">{description}</p>
					</div>
					<div class="prose-section">
						<slot />
					</div>
				</div>
				<div class="image-side">
					<div class="image-wrapper">
						<slot name="image" />
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
